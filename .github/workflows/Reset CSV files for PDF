name: "Actualizare Registre și Curățare PDF"

on:
  workflow_dispatch:

jobs:
  reset_pdf:
    name: "Sincronizare status fizic PDF-uri"
    runs-on: ubuntu-latest

    steps:
      - name: Checkout cod din repository
        uses: actions/checkout@v4

      - name: Configurare Python 3.13
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

      - name: Instalare dependente
        run: |
          python -m pip install --upgrade pip
          pip install google-api-python-client google-auth

      - name: Executare Script Curățare și Resetare
        env:
          GOOGLE_SERVICE_ACCOUNT_JSON: ${{ secrets.GOOGLE_SERVICE_ACCOUNT_JSON }}
          PYTHONUNBUFFERED: "1"
        run: |
         python -u scripts_pdf/inventar_si_reset.py
