      - name: Descărcare cod din repository
        uses: actions/checkout@v4name: Reset XML Tags

on:
  workflow_dispatch:
    inputs:
      forteaza_resetare:
        description: "Forțează resetarea tag-urilor XML (True/False)"
        required: false
        type: boolean
        default: false

jobs:
  reset_tags:
    name: Resetare Tag-uri XML
    runs-on: ubuntu-latest

    steps:
      - name: Descărcare cod din repository
        uses: actions/checkout@v4

      - name: Configurare mediu Python 3.13
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

      - name: Instalare dependențe
        run: |
          python -m pip install --upgrade pip
          pip install google-api-python-client google-auth

      - name: Executare Script Resetare
        env:
          GOOGLE_SERVICE_ACCOUNT_JSON: ${{ secrets.GOOGLE_SERVICE_ACCOUNT_JSON }}
          DRIVE_FOLDER_XML: ${{ vars.DRIVE_FOLDER_XML }}
          FORTEAZA_RESET: ${{ github.event.inputs.forteaza_resetare }}
          PYTHONUNBUFFERED: "1"
        run: |
          # Folosim variabila de mediu izolată pentru a nu strica sintaxa YAML
          if [ "$FORTEAZA_RESET" = "true" ]; then
            echo "🔄 Pornire resetare forțată a tag-urilor XML..."
            # Aici pui apelul către scriptul tău Python care face resetarea, de exemplu:
            # python Scripts_XML/reset_xml_tags.py --force
          else
            echo "▶️ Rulare procesare XML standard (fără resetare totală)..."
            # python Scripts_XML/reset_xml_tags.py
          fi

      - name: Configurare mediu Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Instalare librării necesare
        run: |
          pip install google-auth google-auth-httplib2 google-api-python-client

      - name: Executare Inventar
        env:
          GOOGLE_SERVICE_ACCOUNT_JSON: ${{ secrets.GOOGLE_SERVICE_ACCOUNT_JSON }}
          DRIVE_FOLDER_PDF: ${{ vars.DRIVE_FOLDER_PDF }}
        run: |
          python -u scripts_pdf/inventar_si_reset.py
